rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin(familyId) {
      return request.auth != null &&
        request.auth.uid in
        get(/databases/$(database)/documents/families/$(familyId)).data.adminUids;
    }
    match /families/{familyId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.adminUids;
      allow create: if request.auth != null &&
        request.auth.uid == familyId;
    }
    match /recipes/{recipeId} {
      allow read, write: if isAdmin(resource.data.familyId);
      allow create: if request.auth != null;
    }
    match /mealPlans/{planId} {
      allow read, write: if isAdmin(resource.data.familyId);
      allow create: if request.auth != null;
    }
    match /shoppingItems/{itemId} {
      allow read, write: if isAdmin(resource.data.familyId);
      allow create: if request.auth != null;
    }
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}